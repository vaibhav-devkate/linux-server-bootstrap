# =============================================================================
# .gitignore — vm-setup
# =============================================================================

# ── Secrets & generated outputs ───────────────────────────────────────────────
*.secret
*.secrets
vm-setup-secrets.txt
vm-setup-report.txt
.env
.env.*
!.env.example

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor files ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Temp files ────────────────────────────────────────────────────────────────
/tmp/
*.tmp
*.bak
*.orig

# ── SSH keys (never commit these) ─────────────────────────────────────────────
*.pem
*.key
id_rsa
id_ed25519
id_ecdsa
*.pub

# ── Custom local config overrides ─────────────────────────────────────────────
config/vm-config.local.env
