#!/usr/bin/env bash
# =============================================================================
# VM PRODUCTION SETUP - CENTRAL CONFIGURATION
# =============================================================================
# Edit these values before running the setup script

# ── System ───────────────────────────────────────────────────────────────────
HOSTNAME="prod-server-01"
TIMEZONE="Asia/Kolkata"
LOCALE="en_US.UTF-8"

# ── Users & Roles (Least Privilege) ───────────────────────────────────────────
ADMIN_USER="admin"
ADMIN_GROUP="devops"
ADMIN_PASSWORD=""          # Leave blank to generate randomly (recommended)
ADMIN_SHELL="/bin/bash"

APP_USER="appuser"
APP_GROUP="appuser"

DB_ADMIN_USER="dbadmin"
DB_ADMIN_GROUP="dbadmin"

# ── SSH Configuration ─────────────────────────────────────────────────────────
SSH_PORT=2222              # Non-default port for security
SSH_PUBKEY=""              # Paste your public key here OR use --ssh-key flag
DISABLE_ROOT_LOGIN=true
ALLOW_PASSWORD_AUTH=false  # After adding SSH key, disable password auth

# ── Firewall (UFW) ────────────────────────────────────────────────────────────
ALLOWED_SSH_IPS=""         # Comma-separated IPs to whitelist (empty = any)
OPEN_PORTS="80,443"        # Additional ports to open
ENABLE_IPV6=true

# ── Packages to Install ───────────────────────────────────────────────────────
# These groups are installed in parallel for speed

GROUP_CORE="curl wget git vim nano htop unzip zip tar jq net-tools"
GROUP_SECURITY="fail2ban ufw auditd apparmor-utils rkhunter chkrootkit"
GROUP_MONITORING="prometheus-node-exporter sysstat iotop ncdu"
GROUP_RUNTIME="nodejs npm python3 python3-pip"
GROUP_DATABASE=""          # Example: "postgresql redis-server"
GROUP_EXTRAS="rsync screen tmux tree nmap dnsutils mtr"

# ── Docker ────────────────────────────────────────────────────────────────────
INSTALL_DOCKER=true
ADD_USER_TO_DOCKER=true    # Add ADMIN_USER to docker group

# ── Fail2Ban ──────────────────────────────────────────────────────────────────
FAIL2BAN_MAX_RETRY=3
FAIL2BAN_BAN_TIME=3600     # seconds (1 hour)
FAIL2BAN_FIND_TIME=600     # seconds (10 minutes)

# ── Automatic Security Updates ────────────────────────────────────────────────
ENABLE_AUTO_UPDATES=true
AUTO_REBOOT=false          # Auto-reboot after kernel updates

# ── Swap ──────────────────────────────────────────────────────────────────────
ENABLE_SWAP=true
SWAP_SIZE_GB=2

# ── Log Settings ──────────────────────────────────────────────────────────────
LOG_FILE="/var/log/vm-setup.log"
LOG_LEVEL="INFO"           # DEBUG | INFO | WARN | ERROR

# ── Notification (optional) ───────────────────────────────────────────────────
NOTIFY_EMAIL=""            # Send setup report to this email (requires mailutils)
SLACK_WEBHOOK=""           # Slack webhook URL for notifications
